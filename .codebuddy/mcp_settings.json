{
  "mcp_servers": [
    {
      "name": "chrome-devtools",
      "description": "浏览器自动化E2E测试",
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"],
      "auto_start": true
    },
    {
      "name": "playwright",
      "description": "Playwright端到端测试",
      "command": "npx",
      "args": ["-y", "playwright-mcp@latest"],
      "auto_start": true
    }
  ]
}